<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaRichTextBoxPort.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:AvaloniaRichTextBoxPort.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaRichTextBoxPort.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        KeyDown="Window_KeyDown"
        Title="AvaloniaRichTextBoxPort">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, Auto, Auto, *">
        <Border Grid.Row="0" Background="#EEEEEE" Padding="10">
            <TextBlock Text="Avalonia RichTextBox Custom Port (Phase 4)" FontWeight="Bold" FontSize="18"/>
        </Border>
        
        <StackPanel Grid.Row="1" Orientation="Vertical" Background="#DDDDDD">
            <!-- File Operations -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,10,10,5">
                <Button Name="SaveButton" Content="Save to JSON" Click="SaveButton_Click" />
                <Button Name="LoadButton" Content="Load from JSON" Click="LoadButton_Click" />
                <Button Name="ExportHtmlButton" Content="Export HTML" Click="ExportHtmlButton_Click" Foreground="Green"/>
                <Button Name="PasteHtmlButton" Content="Paste HTML" Click="PasteHtmlButton_Click" Foreground="Green"/>
                <Button Name="InsertImageButton" Content="Insert Image" Click="InsertImageButton_Click" Foreground="Orange"/>
                <Button Name="SampleButton" Content="예제 문서" Click="SampleButton_Click" Foreground="Purple"/>
            </StackPanel>
            
            <!-- Formatting Toolbar -->
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="10,0,10,10">
                <Button Content="B" FontWeight="Bold" Click="BoldButton_Click"/>
                <Button Content="I" FontStyle="Italic" Click="ItalicButton_Click"/>
                <Button Click="UnderlineButton_Click">
                    <TextBlock Text="U" TextDecorations="Underline"/>
                </Button>
                <Button Click="StrikethroughButton_Click">
                    <TextBlock Text="S" TextDecorations="Strikethrough"/>
                </Button>
                
                <TextBlock Text="Size:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox Name="FontSizeComboBox" SelectedIndex="1" SelectionChanged="FontSizeComboBox_SelectionChanged">
                    <ComboBoxItem>12</ComboBoxItem>
                    <ComboBoxItem>14</ComboBoxItem>
                    <ComboBoxItem>18</ComboBoxItem>
                    <ComboBoxItem>24</ComboBoxItem>
                    <ComboBoxItem>32</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Color:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="⬛" Click="ColorBlack_Click"/>
                <Button Content="🟥" Foreground="Red" Click="ColorRed_Click"/>
                <Button Content="🟦" Foreground="Blue" Click="ColorBlue_Click"/>

                <TextBlock Text="Align:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="Left" Click="AlignLeft_Click"/>
                <Button Content="Center" Click="AlignCenter_Click"/>
                <Button Content="Right" Click="AlignRight_Click"/>

                <TextBlock Text="Spacing:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="1.0" Click="Spacing10_Click"/>
                <Button Content="1.5" Click="Spacing15_Click"/>
                <Button Content="2.0" Click="Spacing20_Click"/>

                <Button Content="• List" Click="BulletButton_Click" Margin="10,0,0,0"/>
                <Button Content="1. List" Click="NumberingButton_Click"/>
                <Button Content="Table" Click="InsertTableButton_Click" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Font / heading / highlight / indent -->
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="10,0,10,10">
                <TextBlock Text="Font:" VerticalAlignment="Center"/>
                <ComboBox Name="FontFamilyComboBox" SelectedIndex="0" SelectionChanged="FontFamilyComboBox_SelectionChanged">
                    <ComboBoxItem>Malgun Gothic</ComboBoxItem>
                    <ComboBoxItem>Gulim</ComboBoxItem>
                    <ComboBoxItem>Batang</ComboBoxItem>
                    <ComboBoxItem>Dotum</ComboBoxItem>
                    <ComboBoxItem>Arial</ComboBoxItem>
                    <ComboBoxItem>Times New Roman</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Heading:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="H1" Click="Heading1_Click"/>
                <Button Content="H2" Click="Heading2_Click"/>
                <Button Content="H3" Click="Heading3_Click"/>
                <Button Content="본문" Click="HeadingBody_Click"/>

                <TextBlock Text="Highlight:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="🟨" Click="HighlightYellow_Click"/>
                <Button Content="✕" Click="HighlightNone_Click"/>

                <TextBlock Text="Indent:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="→|" Click="IndentInc_Click"/>
                <Button Content="|←" Click="IndentDec_Click"/>

                <Button Content="― HR" Click="DividerButton_Click" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Name="FindBar" IsVisible="False" Background="#F5F5F5" Padding="10,6" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="찾기:" VerticalAlignment="Center"/>
                <TextBox Name="FindBox" Width="160"/>
                <Button Content="이전" Click="FindPrev_Click"/>
                <Button Content="다음" Click="FindNext_Click"/>
                <TextBlock Text="바꾸기:" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBox Name="ReplaceBox" Width="160"/>
                <Button Content="바꾸기" Click="ReplaceNext_Click"/>
                <Button Content="모두 바꾸기" Click="ReplaceAll_Click"/>
                <CheckBox Name="MatchCaseBox" Content="대소문자 구분" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Name="FindStatus" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray"/>
                <Button Content="✕" Click="CloseFind_Click" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" Padding="20">
            <controls:CustomRichTextBox x:Name="RichTextBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="1000"/>
        </ScrollViewer>
    </Grid>
</Window>
