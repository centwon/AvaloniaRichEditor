<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:AvaloniaRichEditor.Controls"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="720"
        x:Class="AvaloniaRichEditor.Demo.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        KeyDown="Window_KeyDown"
        Width="1180" Height="720"
        Title="AvaloniaRichEditor.Demo">

    <!-- The whole window is just the library's RichEditorView. File/zoom/page actions are injected
         into the view's single toolbar (RichEditorToolbar.LeadingItems/TrailingItems) from code-behind,
         so everything toolbar-related lives in one strip inside the view. -->
    <controls:RichEditorView x:Name="EditorView"
                             PointerWheelChanged="EditorView_PointerWheelChanged"/>

</Window>
